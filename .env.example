# ─────────────────────────────────────────────────────────────────────────────
# HRMS — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=HRMS

# ── Base de données PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=hrms_user
DB_PASSWORD=hrms_password
DB_NAME=hrms_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password

# ── JWT & Sécurité ───────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_super_secret_key_32_chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Keycloak (Auth SSO) ──────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=hrms
KEYCLOAK_CLIENT_ID=hrms-backend
KEYCLOAK_CLIENT_SECRET=change_me_keycloak_secret
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# ── AWS S3 (ou MinIO en développement) ──────────────────────────────────────
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123
AWS_S3_BUCKET=hrms-files
AWS_REGION=ca-central-1
AWS_S3_ENDPOINT=http://localhost:9000   # Retirer en production

# ── SendGrid (Email) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@hrms.com
EMAIL_FROM_NAME=HRMS Système RH

# ── WebSockets ───────────────────────────────────────────────────────────────
WS_PORT=3001

# ── Multi-tenant ─────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=default

# ── Intégrations externes ────────────────────────────────────────────────────
NETHRIS_API_URL=https://api.nethris.com
NETHRIS_API_KEY=your_nethris_api_key
ADP_API_URL=https://api.adp.com
ADP_CLIENT_ID=your_adp_client_id
ADP_CLIENT_SECRET=your_adp_client_secret
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
INDEED_API_KEY=your_indeed_api_key

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3001
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=hrms
VITE_KEYCLOAK_CLIENT_ID=hrms-frontend
